<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.demo1.DashboardController"
            style="-fx-background-color: linear-gradient(to bottom right, #1b2838, #0f1a24);
                   -fx-font-family: 'Segoe UI', 'Roboto', sans-serif;">


    <top>
        <HBox alignment="CENTER_LEFT" spacing="10"
              style="-fx-background-color: #171a21;
                     -fx-padding: 10;">
            <Label text="MyApp"
                   style="-fx-text-fill: #c7d5e0;
                          -fx-font-size: 18px;
                          -fx-font-weight: bold;" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="welcomeLabel" text="Welcome"
                   style="-fx-text-fill: #8f98a0;
                          -fx-font-size: 13px;" />
        </HBox>
    </top>


    <center>
        <VBox alignment="TOP_CENTER" spacing="20"
              style="-fx-padding: 20;">


            <VBox spacing="10" alignment="CENTER"
                  style="-fx-background-color: #171a21;
                         -fx-background-radius: 8;
                         -fx-padding: 15;">
                <Label text="Today's Kindness Task"
                       style="-fx-text-fill: #c7d5e0;
                              -fx-font-size: 16px;
                              -fx-font-weight: bold;" />
                <Label fx:id="taskLabel" wrapText="true"
                       style="-fx-text-fill: #8f98a0;
                              -fx-font-size: 13px;" />
            </VBox>


            <StackPane style="-fx-background-color: #171a21;
                              -fx-background-radius: 8;
                              -fx-padding: 15;">
                <GridPane fx:id="grid"
                          hgap="10"
                          vgap="10"
                          alignment="CENTER"
                          prefWidth="600"
                          prefHeight="300"/>
            </StackPane>


            <HBox spacing="10" alignment="CENTER">


                <Button text="Generate" onAction="#generateTask"
                        style="-fx-background-color: #2a475e;
                               -fx-text-fill: #c7d5e0;
                               -fx-background-radius: 4;
                               -fx-padding: 8 16;
                               -fx-effect: dropshadow(gaussian, transparent, 0, 0, 0, 0);">
                    <style>
                        .button:hover {
                        -fx-background-color: #3b6a8a;
                        -fx-text-fill: white;
                        -fx-effect: dropshadow(gaussian, #66c0f4, 10, 0.4, 0, 0);
                        }
                        .button:pressed {
                        -fx-background-color: #244a63;
                        -fx-translate-y: 1;
                        -fx-scale-x: 0.98;
                        -fx-scale-y: 0.98;
                        }
                    </style>
                </Button>


                <Button text="Complete" onAction="#completeTask"
                        style="-fx-background-color: #5c7e10;
                               -fx-text-fill: white;
                               -fx-background-radius: 4;
                               -fx-padding: 8 16;
                               -fx-effect: dropshadow(gaussian, transparent, 0, 0, 0, 0);">
                    <style>
                        .button:hover {
                        -fx-background-color: #6fa51a;
                        -fx-effect: dropshadow(gaussian, #a4d007, 10, 0.4, 0, 0);
                        }
                        .button:pressed {
                        -fx-background-color: #4f6d0e;
                        -fx-translate-y: 1;
                        -fx-scale-x: 0.98;
                        -fx-scale-y: 0.98;
                        }
                    </style>
                </Button>


                <Button text="Fail" onAction="#failTask"
                        style="-fx-background-color: #8b1a1a;
                               -fx-text-fill: white;
                               -fx-background-radius: 4;
                               -fx-padding: 8 16;
                               -fx-effect: dropshadow(gaussian, transparent, 0, 0, 0, 0);">
                    <style>
                        .button:hover {
                        -fx-background-color: #b22222;
                        -fx-effect: dropshadow(gaussian, #ff4c4c, 10, 0.4, 0, 0);
                        }
                        .button:pressed {
                        -fx-background-color: #6f1414;
                        -fx-translate-y: 1;
                        -fx-scale-x: 0.98;
                        -fx-scale-y: 0.98;
                        }
                    </style>
                </Button>


                <Button text="Undo" onAction="#undoTask"
                        style="-fx-background-color: #2a475e;
                               -fx-text-fill: #c7d5e0;
                               -fx-background-radius: 4;
                               -fx-padding: 8 16;
                               -fx-effect: dropshadow(gaussian, transparent, 0, 0, 0, 0);">
                    <style>
                        .button:hover {
                        -fx-background-color: #3b6a8a;
                        -fx-text-fill: white;
                        -fx-effect: dropshadow(gaussian, #66c0f4, 10, 0.4, 0, 0);
                        }
                        .button:pressed {
                        -fx-background-color: #244a63;
                        -fx-translate-y: 1;
                        -fx-scale-x: 0.98;
                        -fx-scale-y: 0.98;
                        }
                    </style>
                </Button>


                <Button text="Reset" onAction="#resetProgress"
                        style="-fx-background-color: #b8860b;
                               -fx-text-fill: white;
                               -fx-background-radius: 4;
                               -fx-padding: 8 16;
                               -fx-effect: dropshadow(gaussian, transparent, 0, 0, 0, 0);">
                    <style>
                        .button:hover {
                        -fx-background-color: #d4a017;
                        -fx-effect: dropshadow(gaussian, #ffd700, 10, 0.4, 0, 0);
                        }
                        .button:pressed {
                        -fx-background-color: #9c7209;
                        -fx-translate-y: 1;
                        -fx-scale-x: 0.98;
                        -fx-scale-y: 0.98;
                        }
                    </style>
                </Button>

            </HBox>

        </VBox>
    </center>

</BorderPane>
